{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/health",
            "destination": "/api/health.ts"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/[...slug].ts"
        },
        {
            "source": "/((?!api/|assets/).*)",
            "destination": "/index.html"
        }
    ]
}