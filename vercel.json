{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/health",
            "destination": "/api/health.ts"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/[...slug].ts"
        },
        {
            "source": "/((?!api/|assets/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=0, must-revalidate"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}